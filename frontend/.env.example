# Google Cloud Text-to-Speech API key
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Cloud Text-to-Speech API" first
GOOGLE_TTS_API_KEY=your-api-key-here

# OpenAI API key (used for Realtime transcription)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Backend WebSocket URL (optional, defaults to ws://localhost:8000/ws/session)
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/session
